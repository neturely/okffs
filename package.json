{
  "name": "okffs",
  "version": "0.0.1",
  "description": "MCP server for GitHub issue and branch management.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "okffs": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --env-file=.env --import tsx/esm src/index.ts",
    "start": "node --env-file=.env dist/index.js"
  },
  "keywords": [
    "mcp",
    "github",
    "issues",
    "branches",
    "cli"
  ],
  "author": "2b9sa2owa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2b9sa2owa/okffs.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
