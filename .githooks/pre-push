#!/usr/bin/env bash
#
# nas — global pre-push hook (the glados project).
#
# Installed once per machine via:  git config --global core.hooksPath <dir>
# Fires on every `git push` in any repo that does NOT set its own hooksPath.
# Backs up the whole repo to the NAS. NEVER blocks the push: whatever happens
# here, we exit 0.
#
# git passes ref updates on stdin; nas doesn't need them, so we hand it
# /dev/null and let the push proceed regardless of the backup outcome.

gbin="$(command -v nas 2>/dev/null || true)"
[ -n "$gbin" ] || gbin="$HOME/.local/bin/nas"

[ -x "$gbin" ] && "$gbin" backup </dev/null || true

exit 0
