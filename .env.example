# GitHub authentication (required to run the MCP server)
# Personal Access Token with `repo` and `project` scopes.
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Git pre-push NAS Backup Configuration
BACKUP_PASSWORD=your-nas-ftp-password-here
BACKUP_USER=your-username
BACKUP_SERVER="nas.local" // NAS IP address
BACKUP_PATH="/path/to/backups/okffs"